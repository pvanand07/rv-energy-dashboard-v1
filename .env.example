# RV Energy Intelligence — Environment Variables
# Copy this file to .env and adjust values for your deployment.
# Never commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────
# Path to the SQLite database file.
# For Docker: map a volume to persist across container restarts.
DB_PATH=./data/rv_energy.db

# ── Server ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=5000

# Set DEBUG=false in production to suppress stack traces in responses.
DEBUG=true
